<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.program.slitherio"
       name="Slither.io (Brave)"
       version="1.0.0"
       provider-name="Player">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="en">Launch Slither.io in Brave</summary>
        <description lang="en">Opens Slither.io in Brave fullscreen mode.</description>
        <platform>all</platform>
    </extension>
</addon>